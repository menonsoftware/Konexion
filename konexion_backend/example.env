GROQ_API_KEY="gsk_***"
GROQ_URL="https://api.groq.com/openai/v1/models"
OLLAMA_URL="http://localhost:11434"
OLLAMA_TIMEOUT=30
OLLAMA_MAX_TOKENS=2048
SERVER_HOST="0.0.0.0"
SERVER_PORT=8000
DEBUG=false
RELOAD=true
WORKERS=1
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"
LOG_LEVEL="INFO"
ENVIRONMENT="development"

# Vision Models Configuration
# Comma-separated list of model keywords that support vision capabilities
VISION_MODELS="gemma3,llava,scout,maverick,vision,llama-3.2-11b-vision-preview,llama-3.2-90b-vision-preview"

POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-postgres-password"
POSTGRES_DB="konexion_db"

# ── Auth / Security ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="replace-this-with-a-random-64-char-hex-string-at-minimum!!"

# Frontend URL (used for post-login redirect and CORS)
FRONTEND_URL="http://localhost:5173"

# Comma-separated list of enabled OAuth providers
ENABLED_PROVIDERS="google,microsoft"

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth2 ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:8000/api/auth/google/callback"

# ── Microsoft OAuth2 ───────────────────────────────────────────────────────────
# https://portal.azure.com/ → Azure Active Directory → App registrations
# Use "common" for multi-tenant, or a specific tenant UUID for single-tenant
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"
MICROSOFT_TENANT_ID="common"
MICROSOFT_REDIRECT_URI="http://localhost:8000/api/auth/microsoft/callback"
