# Vite env for the frontend container (docker-compose.yml → frontend service env_file).
# The app runs in the browser on your host; use localhost and the published backend port.

# Backend API Configuration
VITE_API_BASE_URL=http://localhost:8000/api

# API proxy path for development (used by Vite dev server)
VITE_API_PROXY_PATH=/api

# WebSocket Configuration
VITE_WS_HOST=localhost:8000
VITE_WS_PATH=/ws/chat

VITE_DEV_MODE=true

# Fallback models when API fails to load models (JSON string)
VITE_DEFAULT_MODELS='[{"model_id":"llama3-8b-8192","context_window":8192,"owned_by":"meta","client_type":"groq"},{"model_id":"mixtral-8x7b-32768","context_window":32768,"owned_by":"mistral","client_type":"groq"},{"model_id":"gemma-7b-it","context_window":8192,"owned_by":"google","client_type":"groq"}]'

VITE_BUFFER_FLUSH_INTERVAL=16
VITE_MIN_CHUNK_SIZE=10
VITE_MAX_RECONNECT_ATTEMPTS=5
VITE_DEFAULT_MAX_TOKENS=2048
